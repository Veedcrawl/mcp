{
  "name": "@veedcrawl/mcp",
  "version": "0.1.0",
  "description": "Official VEEDCRAWL MCP server for transcript, metadata, and AI extraction tools.",
  "type": "module",
  "bin": {
    "veedcrawl-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "claude",
    "veedcrawl",
    "video"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veedcrawl/mcp.git"
  },
  "homepage": "https://github.com/Veedcrawl/mcp#readme",
  "bugs": {
    "url": "https://github.com/Veedcrawl/mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3",
    "dotenv": "^17.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
